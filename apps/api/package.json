{
  "name": "@mge/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "lsof -ti:4000 | xargs kill -9 2>/dev/null || true",
    "dev": "dotenv -e ../../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e ../../../.env -- prisma generate --schema=../../database/prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../../.env -- prisma migrate dev --schema=../../database/prisma/schema.prisma",
    "db:seed": "dotenv -e ../../../.env -- tsx ../../database/seed/index.ts",
    "db:studio": "dotenv -e ../../../.env -- prisma studio --schema=../../database/prisma/schema.prisma"
  },
  "dependencies": {
    "@mge/config": "*",
    "@mge/shared": "*",
    "@mge/types": "*",
    "@mge/utils": "*",
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
