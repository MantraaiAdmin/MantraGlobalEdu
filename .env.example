# Frontend (local dev)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Frontend (production — set in Vercel)
# NEXT_PUBLIC_API_URL=https://api.mantraglobaledu.com/api/v1
