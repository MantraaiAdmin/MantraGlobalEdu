# Database
DATABASE_URL=postgresql://praveen@localhost:5432/mantra_global_education

# API
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
